  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#3a4c4e"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#A5FBFF"
      }
    },
    {
      "name": "Variable Readonly",
      "scope": ["variable.readonly"],
      "settings": {
        "foreground": "#3df2ad"
      }
    },
    {
      "name": "Variable Language",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#dd513c"
      }
    },
    {
