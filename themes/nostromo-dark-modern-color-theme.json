  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4A5A5C"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#A5FBFF"
      }
    },
    {
      "name": "Variable Readonly",
      "scope": ["variable.readonly"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Variable Language",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9AEBF0"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "constant.other.color"],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Control",
      "scope": [
        "keyword.control",
        "keyword.control.import",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Functions",
      "scope": ["function", "entity.name.function", "meta.function-call"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Classes",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Types",
      "scope": ["entity.name.type", "support.type"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Enum Members",
      "scope": ["variable.other.enum-member"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Namespaces",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Structs",
      "scope": ["entity.name.type.struct"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.template"],
      "settings": {
        "foreground": "#5AC0FF"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#F090D0"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Booleans",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.property-name"],
      "settings": {
        "foreground": "#9AEBF0"
      }
    },
    {
      "name": "Property Readonly",
      "scope": ["variable.other.property.readonly"],
      "settings": {
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#E85A45"
      }
    },
    {
      "name": "Tag Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4DFFA8"
      }
    },
    {
      "name": "Tag IDs",
      "scope": ["entity.other.attribute-name.id"],
      "settings": {
        "foreground": "#7AEBFF"
      }
    },
    {
      "name": "Decorators",
