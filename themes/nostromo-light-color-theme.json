  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#8A9A9C"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#0D3D3F"
      }
    },
    {
      "name": "Variable Readonly",
      "scope": ["variable.readonly"],
      "settings": {
        "foreground": "#1A8C5E"
      }
    },
    {
      "name": "Variable Language",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#B54230"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#3A6A8C"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#B54230"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "constant.other.color"],
      "settings": {
        "foreground": "#B54230"
      }
    },
    {
      "name": "Control",
      "scope": [
        "keyword.control",
        "keyword.control.import",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#B54230"
      }
    },
    {
      "name": "Functions",
      "scope": ["function", "entity.name.function", "meta.function-call"],
      "settings": {
        "foreground": "#1A8C5E"
      }
    },
    {
      "name": "Classes",
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Types",
      "scope": ["entity.name.type", "support.type"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Enum Members",
      "scope": ["variable.other.enum-member"],
      "settings": {
        "foreground": "#1A8C5E"
      }
    },
    {
      "name": "Namespaces",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#1A8C5E"
      }
    },
    {
      "name": "Structs",
      "scope": ["entity.name.type.struct"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": {
        "foreground": "#1A8C5E"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.template"],
      "settings": {
        "foreground": "#2A829C"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#A04080"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#1A6A8C"
      }
    },
    {
      "name": "Booleans",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#B54230"
      }
    },
    {
      "name": "Properties",
